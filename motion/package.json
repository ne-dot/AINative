{
  "name": "ai-native-motion",
  "version": "0.1.0",
  "private": true,
  "description": "AI Native 科普视频说明动画（Remotion）",
  "scripts": {
    "dev": "remotion studio",
    "render:flow-traditional": "remotion render src/index.ts FlowTraditional out/flow-traditional.mp4",
    "render:flow-ai-native": "remotion render src/index.ts FlowAiNative out/flow-ai-native.mp4",
    "render:ep02-ai-features-added": "remotion render src/index.ts Ep02AiFeaturesAdded out/ep02-ai-features-added.mp4",
    "render:ep02-workflow-still-on-user": "remotion render src/index.ts Ep02WorkflowStillOnUser out/ep02-workflow-still-on-user.mp4",
    "render:ep02-feature-upgrade": "remotion render src/index.ts Ep02FeatureUpgrade out/ep02-feature-upgrade.mp4",
    "render:ep02-goal-centric-orbit": "remotion render src/index.ts Ep02GoalCentricOrbit out/ep02-goal-centric-orbit.mp4",
    "render:ep02-function-vs-goal-path": "remotion render src/index.ts Ep02FunctionVsGoalPath out/ep02-function-vs-goal-path.mp4",
    "render:ep02-responsibility-shift": "remotion render src/index.ts Ep02ResponsibilityShift out/ep02-responsibility-shift.mp4",
    "render:ep02-judgment-standard": "remotion render src/index.ts Ep02JudgmentStandard out/ep02-judgment-standard.mp4",
    "render:map-demo": "remotion render src/index.ts MapDemo out/map-demo.mp4 --gl=angle --concurrency=1",
    "render:milk-tea-heatmap": "remotion render src/index.ts MilkTeaHeatmapDemo out/milk-tea-heatmap.mp4 --gl=angle --concurrency=1"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.272",
    "@remotion/transitions": "^4.0.484",
    "@turf/turf": "^7.3.5",
    "maplibre-gl": "^5.24.0",
    "material-symbols": "^0.45.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.272"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "typescript": "^5.7.3"
  }
}
